    <!-- Modern Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet">
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root {
            /* Gen Z Aesthetic Palette */
            --bg-color: #f8f7ff;
            --primary-accent: #a29bfe; /* Soft Lavender */
            --secondary-accent: #ffd3e2; /* Aesthetic Pink */
            --text-main: #1a1a1a;
            --text-muted: #555;
            --white: #ffffff;
            --card-shadow: 0 15px 35px rgba(162, 155, 254, 0.12);
            --transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-color);
            color: var(--text-main);
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* Loading Animation */
        @keyframes slideInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .resume-container {
            max-width: 1050px;
            margin: 50px auto;
            background: var(--white);
            display: grid;
            grid-template-columns: 360px 1fr;
            border-radius: 40px;
            overflow: hidden;
            box-shadow: var(--card-shadow);
            animation: slideInUp 0.9s ease-out;
        }

        /* Sidebar Styling */
        .sidebar {
            background: linear-gradient(180deg, #f0eeff 0%, #ffffff 100%);
            padding: 50px 40px;
            border-right: 1px solid #f0f0f0;
        }

        .profile-container {
            text-align: center;
            margin-bottom: 30px;
        }

        .profile-img {
            width: 180px;
            height: 180px;
            border-radius: 50%;
            object-fit: cover;
            border: 6px solid var(--white);
            box-shadow: var(--card-shadow);
            transition: var(--transition);
        }

        .profile-img:hover {
            transform: scale(1.05) rotate(2deg);
        }

        .handle {
            display: block;
            margin-top: 15px;
            font-weight: 600;
            color: var(--primary-accent);
            letter-spacing: 1px;
            font-size: 0.9rem;
        }

        .qr-card {
            background: var(--white);
            padding: 25px;
            border-radius: 25px;
            text-align: center;
            margin: 30px 0;
            box-shadow: 0 8px 20px rgba(0,0,0,0.03);
            border: 2px solid #f8f8ff;
            transition: var(--transition);
        }

        .qr-card:hover {
            border-color: var(--primary-accent);
            transform: translateY(-3px);
        }

        .qr-box {
            width: 110px;
            height: 110px;
            background: #fafafa;
            margin: 0 auto 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 15px;
            border: 1px solid #eee;
        }

        .qr-text {
            font-size: 0.7rem;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1.5px;
        }

        /* Main Content Styling */
        .main-content {
            padding: 60px;
        }

        h1 {
            font-family: 'Playfair Display', serif;
            font-size: 3.2rem;
            line-height: 1.1;
            margin-bottom: 8px;
        }

        .tagline {
            color: var(--primary-accent);
            font-weight: 600;
            letter-spacing: 3px;
            text-transform: uppercase;
            font-size: 0.75rem;
            margin-bottom: 35px;
            display: block;
        }

        .section-header {
            font-family: 'Playfair Display', serif;
            font-size: 1.6rem;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 12px;
            position: relative;
        }

        .section-header::after {
            content: '';
            height: 2px;
            flex-grow: 1;
            background: linear-gradient(90deg, var(--secondary-accent), transparent);
            margin-left: 10px;
        }

        .content-card {
            padding: 25px;
            border-radius: 20px;
            margin-bottom: 20px;
            border: 1px solid #f1f1f1;
            transition: var(--transition);
        }

        .content-card:hover {
            background: #fffaff;
            border-color: var(--primary-accent);
            transform: translateX(10px);
        }

        .pill {
            display: inline-block;
            background: var(--secondary-accent);
            color: #b35d7c;
            padding: 6px 16px;
            border-radius: 30px;
            font-size: 0.8rem;
            margin: 0 8px 10px 0;
            font-weight: 600;
            transition: var(--transition);
        }

        .pill:hover {
            filter: brightness(0.95);
        }

        .contact-link {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 18px;
            font-size: 0.9rem;
            text-decoration: none;
            color: var(--text-main);
            transition: var(--transition);
        }

        .contact-link:hover {
            color: var(--primary-accent);
            transform: translateX(5px);
        }

        .contact-link i {
            color: var(--primary-accent);
            font-size: 1.1rem;
        }

        /* Progress bars for Tech Skills */
        .skill-bar-container {
            margin-bottom: 20px;
        }
        .skill-info {
            display: flex;
            justify-content: space-between;
            font-size: 0.85rem;
            font-weight: 600;
            margin-bottom: 6px;
        }
        .bar-bg {
            height: 10px;
            background: #f0f0f0;
            border-radius: 20px;
            overflow: hidden;
        }
        .bar-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--primary-accent), var(--secondary-accent));
            border-radius: 20px;
        }

        @media (max-width: 900px) {
            .resume-container {
                grid-template-columns: 1fr;
                margin: 0;
                border-radius: 0;
            }
            .sidebar {
                border-right: none;
                border-bottom: 1px solid #f0f0f0;
            }
        }
    </style>
</head>
